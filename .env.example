# Pattern Sleuth Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Set a custom root directory for scans
# PATTERN_SLEUTH_ROOT=/path/to/your/project

# Optional: Custom pattern registry path
# PATTERN_SLEUTH_REGISTRY_PATH=/path/to/custom-patterns.json

# Optional: Custom policy path
# PATTERN_SLEUTH_POLICY_PATH=/path/to/policy.json

# Optional: Output directory for reports
# PATTERN_SLEUTH_OUTPUT_DIR=/path/to/output

# Note: All settings are optional. Pattern Sleuth works out of the box
# with sensible defaults. Only set these if you need custom behavior.
