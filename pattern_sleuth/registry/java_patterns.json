{
  "registry_version": "1.1.0-java-2026-02-21",
  "intent": "Java-specific anti-patterns focusing on AI-generated code issues and semantic problems.",
  "entries": [
    {
      "pattern_id": "neg_java_empty_catch",
      "title": "Empty catch block",
      "polarity": "negative",
      "category": "code_quality",
      "severity": "flag",
      "domain": "any",
      "description": "Empty catch blocks swallow exceptions silently. At minimum, log the exception.",
      "languages": [
        "java"
      ],
      "file_globs": [
        "**/*.java"
      ],
      "detection": {
        "strategy": "regex",
        "signals": [
          "catch\\s*\\([^)]+\\)\\s*\\{\\s*\\}"
        ],
        "false_positive_notes": "Rarely intentional for expected exceptions.",
        "regex": [
          "catch\\s*\\([^)]+\\)\\s*\\{\\s*\\}"
        ]
      },
      "test_cases": {
        "true_positives": [
          "placeholder_test_case"
        ],
        "true_negatives": [
          "# This is a normal comment",
          "def normal_function(): return 42",
          "const value = compute();"
        ]
      },
      "maturity": "draft"
    },
    {
