    {
      "pattern_id": "neg_java_return_null_collection",
      "title": "Returning null instead of empty collection",
      "polarity": "negative",
      "category": "code_quality",
      "severity": "warn",
      "domain": "any",
      "description": "Returning null collections forces null checks. Return empty collections instead.",
      "languages": [
        "java"
      ],
      "file_globs": [
        "**/*.java"
      ],
      "detection": {
        "strategy": "regex",
        "signals": [
          "return null;\\s*//.*empty",
          "return null;\\s*//.*no.*result"
        ],
        "false_positive_notes": "Sometimes intentional to distinguish 'no result' from 'empty result'.",
        "regex": [
          "return null;\\s*//.*empty",
          "return null;\\s*//.*no.*result"
        ]
      },
      "test_cases": {
        "true_positives": [
          "placeholder_test_case"
        ],
        "true_negatives": [
          "# This is a normal comment",
          "def normal_function(): return 42",
          "const value = compute();"
        ]
      },
      "maturity": "draft"
    }
