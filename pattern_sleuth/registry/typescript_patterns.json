    {
      "pattern_id": "neg_ts_any_type",
      "title": "Use of `any` type",
      "polarity": "negative",
      "category": "code_quality",
      "severity": "warn",
      "domain": "any",
      "description": "Using `any` disables TypeScript's type checking. Prefer `unknown` or specific types.",
      "languages": [
        "typescript"
      ],
      "file_globs": [
        "**/*.{ts,tsx}"
      ],
      "sources": {
        "external_intelligence": "typescript-eslint no-explicit-any"
      },
      "detection": {
        "strategy": "regex",
        "signals": [
          ": any[\\s,\\[\\]<>]",
          ": any\\b"
        ],
        "false_positive_notes": "Sometimes needed for third-party library types or gradual migration.",
        "regex": [
          ": any\\b",
          ": any[\\s,\\[\\]<>]"
        ]
      },
      "test_cases": {
        "true_positives": [
          "placeholder_test_case"
        ],
        "true_negatives": [
          "# This is a normal comment",
          "def normal_function(): return 42",
          "const value = compute();"
        ]
      },
      "maturity": "draft"
    },
