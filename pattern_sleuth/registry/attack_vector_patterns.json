    {
      "pattern_id": "sec_metasploit_command_injection",
      "title": "Command injection - Metasploit exploitable",
      "polarity": "negative",
      "category": "security",
      "severity": "block",
      "domain": "any",
      "description": "OS command injection vulnerabilities exploitable via Metasploit payloads. User input passed to system commands.",
      "languages": [
        "python",
        "java",
        "php",
        "ruby",
        "any"
      ],
      "file_globs": [
        "**/*.{py,java,php,rb}"
      ],
      "sources": {
        "attack_tool": "metasploit",
        "mitre_attack": "T1199",
        "cwe": "CWE-78"
      },
      "detection": {
        "strategy": "regex",
        "signals": [
          "os\\.system\\(.*\\+",
          "subprocess\\.call\\(.*shell=True",
          "subprocess\\.Popen\\(.*shell=True",
          "Runtime\\.getRuntime\\(\\)\\.exec\\(",
          "exec\\(.*\\$",
          "shell_exec\\(",
          "system\\(.*\\$",
          "passthru\\(",
          "popen\\("
        ],
        "false_positive_notes": "Some legitimate use cases exist - review context carefully.",
        "regex": [
          "os\\.system\\s*\\([^)]*\\+",
          "subprocess\\.(call|Popen|run).*\\+",
          "exec\\s*\\([\"\\'][^\"\\']*\\+",
          "\\.\\s*system\\s*\\([^)]*\\+"
        ]
      },
      "mitigation": "Use subprocess without shell=True. Use allowlists for commands. Sanitize all input.",
      "test_cases": {
        "true_positives": [
          "os.system(\"ls \" + user_input)",
          "subprocess.call(\"ping \" + host, shell=True)",
          "exec(\"cat \" + filename)"
        ],
        "true_negatives": [
          "subprocess.run([\"ping\", \"-c\", \"1\", host])",
          "# shell injection warning",
          "def system_call(args): pass"
        ]
      },
      "maturity": "draft"
    },
