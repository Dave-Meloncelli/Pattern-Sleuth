{
  "registry_version": "1.2.0-attack-vector-2026-02-21",
  "intent": "Patterns derived from offensive security tools (nmap, metasploit, sqlmap, burp, hydra, etc.) for defensive detection. These patterns help identify vulnerable code and detect attack signatures.",
  "entries": [
    {
      "pattern_id": "sec_sqlmap_union_injection",
      "title": "SQL Injection (UNION-based) - SQLMap detectable",
      "polarity": "negative",
      "category": "security",
      "severity": "block",
      "domain": "any",
      "description": "Code vulnerable to UNION-based SQL injection as detected by sqlmap. String concatenation in SQL queries allows UNION attacks.",
      "languages": [
        "python",
        "java",
        "php",
        "any"
      ],
      "file_globs": [
        "**/*.{py,java,php,sql}"
      ],
      "sources": {
        "attack_tool": "sqlmap",
        "mitre_attack": "T1190",
        "cwe": "CWE-89"
      },
      "detection": {
        "strategy": "regex",
        "signals": [
          "\".*\\+.*SELECT.*FROM",
          "'.*\\+.*SELECT.*FROM",
          "f\".*{.*}.*SELECT",
          "f'.*{.*}.*SELECT",
          "\\.format\\(.*SELECT",
          "%.*SELECT.*FROM"
        ],
        "false_positive_notes": "May trigger on SQL generation in ORM or query builders with proper escaping.",
        "regex": [
          "SELECT.*FROM.*[\"\\']\\s*\\+",
          "[\"\\'].*SELECT.*FROM.*[\"\\'].*\\+",
          "f[\"\\'].*SELECT.*\\{",
          "`.*SELECT.*\\$\\{",
          "\\.format\\(.*SELECT",
          "%.*SELECT.*FROM"
        ]
      },
      "mitigation": "Use parameterized queries with prepared statements. Never concatenate user input into SQL.",
      "test_cases": {
        "true_positives": [
          "query = \"SELECT * FROM users WHERE id = \" + user_input",
          "cursor.execute(\"SELECT * FROM products WHERE name LIKE '%\" + name + \"%'\")",
          "query = f'SELECT * FROM users WHERE id = {user_id}'",
          "const query = `SELECT * FROM users WHERE id = ${userId}`;",
          "String query = \"SELECT * FROM users WHERE id = \" + userId;"
        ],
        "true_negatives": [
          "cursor.execute(\"SELECT * FROM users WHERE id = ?\", (user_id,))",
          "const query = \"SELECT * FROM users WHERE id = $1\";",
          "# Comment about SELECT"
        ]
      },
      "maturity": "draft"
    },
    {
      "pattern_id": "sec_sqlmap_boolean_blind",
      "title": "SQL Injection (Boolean-based blind) - SQLMap detectable",
      "polarity": "negative",
      "category": "security",
      "severity": "block",
      "domain": "any",
      "description": "Code vulnerable to boolean-based blind SQL injection where attackers can infer data from true/false responses.",
      "languages": [
        "python",
        "java",
        "php",
        "any"
      ],
      "file_globs": [
        "**/*.{py,java,php}"
      ],
      "sources": {
        "attack_tool": "sqlmap",
        "cwe": "CWE-89"
      },
      "detection": {
        "strategy": "regex",
        "signals": [
          "\".*WHERE.*\".*\\+.*\\w",
          "'.*WHERE.*'.*\\+.*\\w",
          "\".*AND.*\".*\\+.*\\w",
          "'.*AND.*'.*\\+.*\\w",
          "\".*OR.*\".*\\+.*\\w",
          "'.*OR.*'.*\\+.*\\w",
          "f\".*{.*}.*WHERE",
          "f'.*{.*}.*WHERE",
          "\\.format\\(.*WHERE"
        ],
        "false_positive_notes": "Only flags string concatenation in SQL. F-strings and format() with SQL are flagged.",
        "regex": [
          "SELECT.*FROM.*[\"\\']\\s*\\+",
          "[\"\\'].*SELECT.*[\"\\'].*\\+"
        ]
      },
      "mitigation": "Use parameterized queries. Implement input validation.",
      "test_cases": {
        "true_positives": [
          "query = \"SELECT * FROM users WHERE id = \" + user_input",
          "cursor.execute(\"SELECT * FROM products WHERE name LIKE '%\" + name + \"%'\")",
          "query = f'SELECT * FROM users WHERE id = {user_id}'",
          "String query = \"SELECT * FROM users WHERE id = \" + userId;",
          "$query = \"SELECT * FROM users WHERE id = \" . $userId;"
        ],
        "true_negatives": [
          "cursor.execute(\"SELECT * FROM users WHERE id = ?\", (user_id,))",
          "const query = \"SELECT * FROM users WHERE id = $1\";",
          "// This is a comment about SELECT statements"
        ]
      },
      "maturity": "draft"
    },
